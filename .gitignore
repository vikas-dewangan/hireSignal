# ─── Gradle ───────────────────────────────────────────────
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Gradle wrapper (keep the jar, ignore everything else)
gradle/wrapper/gradle-wrapper.properties

# ─── IntelliJ IDEA ────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ─── Spring Boot ──────────────────────────────────────────
**/application-local.yml
**/application-prod.yml
**/application-staging.yml

# ─── Secrets — never commit these ─────────────────────────
*.env
.env
.env.*
secrets/
**/src/main/resources/application-secrets.yml

# ─── Java ─────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# ─── Docker ───────────────────────────────────────────────
# Keep docker-compose.yml but ignore override files
docker-compose.override.yml
docker-compose.local.yml

# ─── Logs ─────────────────────────────────────────────────
*.log
logs/
**/logs/

# ─── OS files ─────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Mac
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ─── VS Code (if anyone uses it) ──────────────────────────
.vscode/
*.code-workspace

# ─── Node (for React/Angular frontend — Phase 2) ──────────
node_modules/
dist/
.next/
.nuxt/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Test output ──────────────────────────────────────────
**/test-results/
**/surefire-reports/
coverage/
*.exec

# ─── Keep these — DO commit ───────────────────────────────
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!docker-compose.yml
!infra/
